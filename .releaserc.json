{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    "@semantic-release/github",
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "./verify.sh . HiveShard",
        "publishCmd": "./release.sh . HiveShard ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "./verify.sh . HiveShard.Client",
        "publishCmd": "./release.sh . HiveShard.Client ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "./verify.sh . HiveShard.Edge",
        "publishCmd": "./release.sh . HiveShard.Edge ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "./verify.sh . HiveShard.Shard",
        "publishCmd": "./release.sh . HiveShard.Shard ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/exec",
      {
